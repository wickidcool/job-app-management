{
  "name": "job-application-manager",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev --workspace=@wic/web",
    "dev:api": "npm run dev --workspace=@wic/api",
    "build": "npm run build --workspaces --if-present",
    "build:web": "npm run build --workspace=@wic/web",
    "build:api": "npm run build --workspace=@wic/api",
    "lint": "npm run lint --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "format": "prettier --write \"packages/**/*.{ts,tsx,css,md}\"",
    "format:check": "prettier --check \"packages/**/*.{ts,tsx,css,md}\"",
    "db:migrate": "npm run db:migrate --workspace=@wic/api",
    "db:push": "npm run db:push --workspace=@wic/api"
  },
  "devDependencies": {
    "prettier": "^3.8.3"
  }
}
