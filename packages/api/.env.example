# Server configuration
PORT=3000
HOST=127.0.0.1
NODE_ENV=development

# Required: PostgreSQL connection URL
DATABASE_URL=postgresql://postgres:yourpassword@localhost:5432/job_app_manager

# Optional: directory for local data files
DATA_DIR=./data

# Optional: Anthropic API key for AI-powered features (resume parsing, job fit analysis)
# When set, LLM-powered features use Claude to extract and analyze structured data
ANTHROPIC_API_KEY=
# Optional: Claude model to use for LLM features (default: claude-sonnet-4-6)
LLM_MODEL=

# Optional: Supabase auth configuration
# When set, all /api/* endpoints require a valid Supabase JWT Bearer token.
# Omit these to run without auth (local single-user dev mode).
# For local Supabase: run `supabase status` to get these values.
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_JWT_SECRET=

# Optional: Cloudflare R2 (or S3-compatible) storage configuration
# When set, resume files are stored in R2 instead of the local filesystem.
# For local development with MinIO: R2_ENDPOINT=http://localhost:9000
# For Cloudflare R2: R2_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
R2_ENDPOINT=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
