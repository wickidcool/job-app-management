# Server configuration
PORT=3000
HOST=127.0.0.1
NODE_ENV=development

# Required: PostgreSQL connection URL
DATABASE_URL=postgresql://postgres:yourpassword@localhost:5432/job_app_manager

# Optional: directory for local data files
DATA_DIR=./data

# Optional: Anthropic API key for AI-powered resume parsing
# When set, resumes are parsed using Claude to extract structured STAR-format data
ANTHROPIC_API_KEY=

# Optional: Supabase auth configuration
# When set, all /api/* endpoints require a valid Supabase JWT Bearer token.
# Omit these to run without auth (local single-user dev mode).
# For local Supabase: run `supabase status` to get these values.
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_JWT_SECRET=
