{
  "name": "@wic/api",
  "private": true,
  "version": "1.0.0",
  "description": "Hono backend for Job Application Manager (Cloudflare Workers + Node.js)",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx src/db/migrate.ts",
    "db:push": "drizzle-kit push",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.90.0",
    "@aws-sdk/client-s3": "^3.1040.0",
    "@aws-sdk/s3-request-presigner": "^3.1040.0",
    "@hono/node-server": "^1.13.7",
    "@supabase/supabase-js": "^2.49.8",
    "docx": "^9.6.1",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.30.10",
    "hono": "^4.7.10",
    "jose": "^6.2.3",
    "mammoth": "^1.12.0",
    "pdf-parse": "^2.4.5",
    "pdfjs-dist": "^5.4.296",
    "postgres": "^3.4.4",
    "ulid": "^2.3.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250430.0",
    "@types/node": "^20.14.0",
    "@vitest/coverage-v8": "^1.6.0",
    "drizzle-kit": "^0.21.4",
    "tsx": "^4.15.1",
    "typescript": "^5.4.5",
    "vitest": "^1.6.0"
  }
}
