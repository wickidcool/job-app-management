# Cloudflare Workers local dev secrets (copy to .dev.vars, never commit .dev.vars)
# wrangler dev reads these automatically as Worker secrets/vars
#
# Binding names match packages/api/src/types/env.ts (Env interface)

# Supabase auth
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_JWT_SECRET=your-jwt-secret

# Anthropic API
ANTHROPIC_API_KEY=sk-ant-...

# Note: DATABASE_URL is NOT used in the Worker — the HYPERDRIVE binding handles PostgreSQL.
# wrangler dev uses the localConnectionString from wrangler.jsonc for local Hyperdrive emulation.
# If you need to override it locally, set DATABASE_URL here:
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/postgres

# Note: R2_BUCKET is a native binding defined in wrangler.jsonc — no env var needed.
# wrangler dev automatically provides a local R2 bucket emulation.
